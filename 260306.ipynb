      "cell_type": "code",
      "source": [
        "a = float(input(\"첫 번째 숫자: \"))\n",
        "b = float(input(\"두 번째 숫자: \"))\n",
        "\n",
        "print(\"덧셈:\", a + b)\n",
        "print(\"뺄셈:\", a - b)\n",
        "print(\"곱셈:\", a * b)\n",
        "\n",
        "if b != 0:\n",
        "    print(\"나눗셈:\", a / b)\n",
        "else:\n",
        "    print(\"0으로 나눌 수 없습니다\")\n",
        ""
      ],
